  "keyFeatures": [
    "Access to YouTube's private InnerTube API",
    "Video info, streaming data, and download support",
    "YouTube Music, YouTube Kids, and YouTube Studio clients",
    "Live chat monitoring with event-driven API",
    "OAuth2 authentication via device code flow",
    "Search with advanced filtering",
    "Channel, playlist, and comments browsing",
    "Cross-platform: Node.js, Deno, Browser, React Native, Cloudflare Workers",
    "Protobuf-based request encoding",
    "Caching support via UniversalCache"
  ],
  "publicApiSurface": [
    "Innertube.create(config)",
    "Innertube.getInfo(videoId)",
    "Innertube.getBasicInfo(videoId)",
    "Innertube.search(query, filters)",
    "Innertube.getChannel(id)",
    "Innertube.getPlaylist(id)",
    "Innertube.getComments(videoId)",
    "Innertube.getHomeFeed()",
    "Innertube.download(videoId, options)",
    "Innertube.getStreamingData(videoId, options)",
    "Innertube.music (Music client)",
    "Innertube.studio (Studio client)",
    "Innertube.kids (Kids client)",
    "Innertube.account (AccountManager)",
    "Innertube.playlist (PlaylistManager)",
    "Innertube.interact (InteractionManager)",
    "OAuth2.init(tokens)",
    "Session.create(config)",
    "UniversalCache",
    "YTNodes"
  ]
